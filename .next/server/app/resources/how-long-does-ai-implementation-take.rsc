1a:["$","div",null,{"className":"cta-box","style":{"margin":"32px 0"},"children":["$","$L23",null,{"href":"/","location":"resource_mid_how-long-does-ai-implementation-take"}]}]
1b:["$","section","0",{"children":[["$","h2",null,{"children":"The 30-Day Planning Phase"}],"$undefined",[["$","p","0",{"children":"<strong>Days 1–3:</strong> Strategic Vision definition. What business goal does AI serve? How will you measure success? This produces your one-page Strategic Vision Canvas."}],["$","p","1",{"children":"<strong>Days 4–7:</strong> Starting Point Assessment. What is the current state of your most important workflow? What data do you have? By the end of Week 1, you have more clarity than most businesses reach after months of AI experimentation."}],["$","p","2",{"children":"<strong>Days 8–14:</strong> Strategy selection, workflow mapping, and task deconstruction. Your workflows are mapped, your tasks are scored, and your priority AI opportunities are identified with evidence."}],["$","p","3",{"children":"<strong>Days 15–21:</strong> AI Task Canvas completion for your top use cases, and process mapping. The build briefs are written. You know exactly what you are building."}],["$","p","4",{"children":"<strong>Days 22–28:</strong> Tool identification, implementation plan construction, and Phase 1 scoping."}],["$","p","5",{"children":"<strong>Day 30:</strong> You have a complete, written AI implementation plan. The first phase of execution begins."}]]]}]
1c:["$","section","1",{"children":[["$","h2",null,{"children":"Tier 1 Implementation — 4 to 8 Weeks"}],"$undefined",[["$","p","0",{"children":"Tier 1 use cases — AI that does not require historical training data — are the fastest to deploy. Product description AI, WhatsApp concierge, appointment reminder systems, document processing AI. The implementation involves configuration, integration, and testing rather than model training."}],["$","p","1",{"children":"4 weeks is achievable for a single Tier 1 use case with a clear brief. 8 weeks accounts for integration complexity and iteration. By week 8, most businesses have a live, working Tier 1 AI system — and are already capturing the data they need for Tier 2."}]]]}]
1d:["$","section","2",{"children":[["$","h2",null,{"children":"Tier 2 Implementation — 2 to 4 Months"}],"$undefined",[["$","p","0",{"children":"Tier 2 use cases require 30–60 days of operational data before the AI can function effectively. The data accumulates during and after Tier 1 deployment. Implementation begins when the data threshold is reached. Recommendation engines, predictive scheduling, personalisation systems."}]]]}]
1e:["$","section","3",{"children":[["$","h2",null,{"children":"Tier 3 Implementation — 6 to 12 Months"}],"$undefined",[["$","p","0",{"children":"Tier 3 use cases — demand forecasting, customer lifetime value modelling, advanced personalisation — require 6 to 12 months of structured operational history. These are planned from the start but deployed last. The first 6 months of Tier 1 and Tier 2 operation are building the data foundation for Tier 3."}]]]}]
1f:["$","section",null,{"children":[["$","h2",null,{"children":"Frequently Asked Questions"}],["$","$L24",null,{"faqs":[{"q":"Can AI be implemented faster than 30 days?","a":"Some businesses try to compress the planning phase — and sometimes succeed in deploying an AI tool in days. The question is whether what they deploy solves the right problem in the right workflow with the right oversight structure. Speed without planning is what produces the failed AI pilots that cost more than they save. 30 days of planning prevents 6 months of misdirected implementation."},{"q":"What slows down AI implementation most?","a":"Data readiness is the most common bottleneck. Discovering that the data required for a specific use case does not exist in accessible, structured form — after the planning process has already selected that use case — adds 4–8 weeks of data preparation. The AI Navigator framework addresses this in Week 1 by assessing data readiness before committing to a use case."},{"q":"How many AI use cases can be implemented simultaneously?","a":"For most SMEs, one Tier 1 use case at a time is the right pace. Attempting multiple simultaneous implementations splits team attention, complicates the feedback loops, and makes it harder to attribute results to specific changes. Once the first use case is live and stable, the second can begin."},{"q":"What is the minimum viable AI implementation for a small business?","a":"The minimum viable AI implementation is a single, well-defined use case that solves a clearly identified workflow problem. A WhatsApp auto-responder that handles 70% of routine enquiries. An AI description generator that produces bilingual product copy in hours rather than days. The value is real and measurable even at the smallest scale."},{"q":"Does AI require ongoing maintenance after implementation?","a":"Yes. AI systems require monitoring, feedback processing, and periodic recalibration as business conditions change. The governance framework established in Chapter 11 of the AI Navigator defines the ongoing management cadence — typically a monthly review of performance metrics and a quarterly assessment of whether the use case scope needs expanding."}]}]]}]
20:["$","div",null,{"className":"cta-box","children":[["$","h2",null,{"style":{"marginTop":0},"children":"Ready to assess your AI readiness?"}],["$","p",null,{"children":"The AI Readiness Assessment evaluates your business across five dimensions — workflow type, decision complexity, data availability, process volume, and team size — and gives you a personalised score with specific recommended next steps. It takes three minutes."}],["$","$L23",null,{"href":"/","location":"resource_bottom_how-long-does-ai-implementation-take"}]]}]
21:["$","div",null,{"className":"author-bio","children":[["$","p",null,{"children":[["$","strong",null,{"children":"Allan Sendagi"}]," is the author of ",["$","em",null,{"children":"The AI Roadmap"}]," and founder of SafeHaven AI. He works with SMEs across Qatar and the GCC to build structured AI implementation plans using the AI Navigator framework."]}],["$","p",null,{"style":{"marginTop":8},"children":[["$","a",null,{"href":"/","style":{"color":"var(--brand)","fontWeight":600},"children":"Take the free AI Readiness Assessment"}]," · ",["$","a",null,{"href":"https://calendly.com/allan-safehavenai/30min","style":{"color":"var(--brand)","fontWeight":600},"children":"Book a discovery call"}]]}]]}]
