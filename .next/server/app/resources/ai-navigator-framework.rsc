13:{"metadata":[["$","title","0",{"children":"The AI Navigator Framework — A Complete Guide | AI Navigator"}],["$","meta","1",{"name":"description","content":"The AI Navigator is an 11-step framework for SMEs that builds a complete AI implementation plan — from Strategic Vision to live execution. Created by Allan Sendagi, author of The AI Roadmap."}],["$","link","2",{"rel":"canonical","href":"https://www.ainavsystem.com/resources/ai-navigator-framework/"}],["$","meta","3",{"property":"og:title","content":"The AI Navigator Framework — A Complete Guide"}],["$","meta","4",{"property":"og:description","content":"The AI Navigator is an 11-step framework for SMEs that builds a complete AI implementation plan — from Strategic Vision to live execution. Created by Allan Sendagi, author of The AI Roadmap."}],["$","meta","5",{"property":"og:url","content":"https://www.ainavsystem.com/resources/ai-navigator-framework/"}],["$","meta","6",{"property":"og:type","content":"article"}],["$","meta","7",{"name":"twitter:card","content":"summary"}],["$","meta","8",{"name":"twitter:title","content":"The AI Navigator Framework — A Complete Guide"}],["$","meta","9",{"name":"twitter:description","content":"The AI Navigator is an 11-step framework for SMEs that builds a complete AI implementation plan — from Strategic Vision to live execution. Created by Allan Sendagi, author of The AI Roadmap."}]],"error":null,"digest":"$undefined"}
