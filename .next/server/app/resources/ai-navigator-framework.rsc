19:T847,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Who created the AI Navigator framework?","acceptedAnswer":{"@type":"Answer","text":"The AI Navigator framework was created by Allan Sendagi, founder of SafeHaven AI and author of The AI Roadmap. The framework was developed through applied consulting work with SMEs across Qatar, the GCC, and internationally, and published in book form in April 2025."}},{"@type":"Question","name":"Is the AI Navigator framework only for technology companies?","acceptedAnswer":{"@type":"Answer","text":"No. The framework is industry-agnostic and was specifically designed for businesses where AI is not the product but a tool for improving operations. Retail, logistics, legal services, healthcare, financial services, hospitality, real estate, and professional services businesses have all used the framework successfully."}},{"@type":"Question","name":"How is the AI Navigator different from a generic AI assessment?","acceptedAnswer":{"@type":"Answer","text":"A generic AI assessment tells you roughly where you stand on a maturity scale. The AI Navigator framework produces actionable written documents — a specific Strategic Vision, a ranked task list, an AI Task Canvas for each use case, a process map, and a phased implementation plan. The difference is the difference between a diagnosis and a prescription."}},{"@type":"Question","name":"Can the framework be applied to a business that has already started using AI tools?","acceptedAnswer":{"@type":"Answer","text":"Yes. Chapter 2's Starting Point Analysis is specifically designed to evaluate businesses at any stage — including those that have already deployed tools without a structured plan."}},{"@type":"Question","name":"How long does it take to work through the complete framework?","acceptedAnswer":{"@type":"Answer","text":"In the guided consulting engagement, the complete framework is covered in four sessions over four weeks. In the self-guided book format, most business owners complete all eleven chapters over six to eight weeks of dedicated weekly sessions."}}]}f:[["$","$L2",null,{"id":"faq-schema","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$19"}}],["$","$L2",null,{"id":"author-schema","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"The AI Navigator Framework — A Complete Guide\",\"author\":{\"@type\":\"Person\",\"name\":\"Allan Sendagi\",\"url\":\"https://www.ainavsystem.com/about/\",\"sameAs\":[\"https://www.linkedin.com/in/allansendagi/\",\"https://allansendagi.gumroad.com/l/ainavigatorsystem\"]},\"publisher\":{\"@type\":\"Organization\",\"name\":\"SafeHaven AI\",\"url\":\"https://www.ainavsystem.com\"},\"url\":\"https://www.ainavsystem.com/resources/ai-navigator-framework/\"}"}}],["$","div",null,{"className":"article-wrap","children":[["$","nav",null,{"className":"breadcrumb","aria-label":"Breadcrumb","children":[["$","a",null,{"href":"/","children":"Home"}],["$","span",null,{"aria-hidden":"true","children":" › "}],["$","a",null,{"href":"/resources/","children":"Resources"}],["$","span",null,{"aria-hidden":"true","children":" › "}],["$","span",null,{"children":"The AI Navigator Framework — A Complete Guide"}]]}],["$","h1",null,{"children":"The AI Navigator Framework — A Complete Guide"}],[["$","p","0",{"children":"The AI Navigator is an 11-step framework for building a complete AI implementation plan. It was created specifically for small and medium-sized businesses — organisations that need AI to work in practice, not in theory, and that cannot afford to waste months on experiments that go nowhere."}],"$L1a","$L1b"],"$L1c",["$L1d","$L1e","$L1f","$L20","$L21","$L22"],"$L23","$L24","$undefined","$L25","$L26"]}]]
