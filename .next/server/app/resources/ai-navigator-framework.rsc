28:I[6203,["619","static/chunks/619-ba102abea3e3d0e4.js","549","static/chunks/app/(site)/resources/%5Bslug%5D/page-82b918b41d4220bf.js"],"default"]
1a:["$","p","1",{"children":"The framework begins with a single question: what business goal should AI serve? Every step that follows flows from the answer to that question. By the end of the process, a business holds a complete set of written documents that translate AI from an intention into an operational roadmap."}]
1b:["$","p","2",{"children":"The AI Navigator framework is the methodology behind the book The AI Roadmap, written by Allan Sendagi and published in April 2025."}]
1c:["$","div",null,{"className":"cta-box","style":{"margin":"32px 0"},"children":["$","$L27",null,{"href":"/","location":"resource_mid_ai-navigator-framework"}]}]
1d:["$","section","0",{"children":[["$","h2",null,{"children":"Why This Framework Exists"}],"$undefined",[["$","p","0",{"children":"The problem is not the technology. The technology is ready. The problem is the approach most businesses take to adopting it. They start with tools. Someone signs up for ChatGPT. A manager attends a demo. A team runs experiments. Months pass. The results are scattered, the ROI is unclear, and leadership is asking what the return on all this investment actually is."}],["$","p","1",{"children":"The AI Navigator framework was built to solve this problem. Its core principle is simple: don't start with a vendor, don't start with code, don't start with data. Start with direction."}]]]}]
1e:["$","section","1",{"children":[["$","h2",null,{"children":"Chapter 1 — Strategic Vision"}],"$undefined",[["$","p","0",{"children":"<strong>What it does:</strong> Establishes the business goal that AI must serve. Forces clarity on purpose before any technology is discussed."}],["$","p","1",{"children":"<strong>The tool:</strong> The Strategic Vision Canvas. Four questions answered with precision: What is the business goal? What is the specific AI use case? What outcomes do we expect? How will we measure success?"}],["$","p","2",{"children":"<strong>The output:</strong> Your Strategic Vision Statement — a one-page document that anchors every subsequent step."}]]]}]
1f:["$","section","2",{"children":[["$","h2",null,{"children":"Chapters 2–5: Analysis and Strategy"}],"$undefined",[["$","p","0",{"children":"Chapter 2 (Starting Point Analysis) establishes an honest picture of where your business currently stands. Chapter 3 (Strategy Selection) produces a documented choice between Evolutionary and Revolutionary approaches. Chapter 4 (Strategy Preferences) calibrates scope, data readiness, and timeline. Chapter 5 (Workflow Analysis) identifies which workflows are worth improving with AI — and which are not."}]]]}]
20:["$","section","3",{"children":[["$","h2",null,{"children":"Chapters 6–9: Design and Tool Selection"}],"$undefined",[["$","p","0",{"children":"Chapter 6 (Task Deconstruction) scores each task on predictability, data availability, decision complexity, and frequency. Chapter 7 (AI Task Canvas) turns good ideas into precise build briefs. Chapter 8 (Process Mapping) creates visual blueprints of AI-integrated workflows. Chapter 9 (Tool Identification) uses the 2×2 AI Functionality Matrix to identify tool categories before any vendor is evaluated."}]]]}]
21:["$","section","4",{"children":[["$","h2",null,{"children":"Chapters 10–11: Execution"}],"$undefined",[["$","p","0",{"children":"Chapter 10 (Implementation Plan) translates everything into a phased, operational project plan with objectives, tasks, timelines, budgets, owners, metrics, and risks. Chapter 11 (Execution and Iteration) initiates Phase 1 and establishes the governance and monitoring framework that ensures the AI system improves over time."}]]]}]
22:["$","section","5",{"children":[["$","h2",null,{"children":"What You Hold at the End"}],"$undefined",[["$","p","0",{"children":"A business that completes the AI Navigator framework holds eleven specific documents. They are not generic templates. They are built around your business, your workflows, your data, and your goals. Together they constitute your AI Playbook — usable independently of any consultant, by any development team, with any future partner."}]]]}]
23:["$","section",null,{"children":[["$","h2",null,{"children":"Frequently Asked Questions"}],["$","$L28",null,{"faqs":[{"q":"Who created the AI Navigator framework?","a":"The AI Navigator framework was created by Allan Sendagi, founder of SafeHaven AI and author of The AI Roadmap. The framework was developed through applied consulting work with SMEs across Qatar, the GCC, and internationally, and published in book form in April 2025."},{"q":"Is the AI Navigator framework only for technology companies?","a":"No. The framework is industry-agnostic and was specifically designed for businesses where AI is not the product but a tool for improving operations. Retail, logistics, legal services, healthcare, financial services, hospitality, real estate, and professional services businesses have all used the framework successfully."},{"q":"How is the AI Navigator different from a generic AI assessment?","a":"A generic AI assessment tells you roughly where you stand on a maturity scale. The AI Navigator framework produces actionable written documents — a specific Strategic Vision, a ranked task list, an AI Task Canvas for each use case, a process map, and a phased implementation plan. The difference is the difference between a diagnosis and a prescription."},{"q":"Can the framework be applied to a business that has already started using AI tools?","a":"Yes. Chapter 2's Starting Point Analysis is specifically designed to evaluate businesses at any stage — including those that have already deployed tools without a structured plan."},{"q":"How long does it take to work through the complete framework?","a":"In the guided consulting engagement, the complete framework is covered in four sessions over four weeks. In the self-guided book format, most business owners complete all eleven chapters over six to eight weeks of dedicated weekly sessions."}]}]]}]
24:["$","div",null,{"className":"cta-box","children":[["$","h2",null,{"style":{"marginTop":0},"children":"Ready to assess your AI readiness?"}],["$","p",null,{"children":"The AI Readiness Assessment evaluates your business across five dimensions — workflow type, decision complexity, data availability, process volume, and team size — and gives you a personalised score with specific recommended next steps. It takes three minutes."}],["$","$L27",null,{"href":"/","location":"resource_bottom_ai-navigator-framework"}]]}]
25:["$","div",null,{"className":"author-bio","children":[["$","p",null,{"children":[["$","strong",null,{"children":"Allan Sendagi"}]," is the author of ",["$","em",null,{"children":"The AI Roadmap"}]," and founder of SafeHaven AI. He works with SMEs across Qatar and the GCC to build structured AI implementation plans using the AI Navigator framework."]}],["$","p",null,{"style":{"marginTop":8},"children":[["$","a",null,{"href":"/","style":{"color":"var(--brand)","fontWeight":600},"children":"Take the free AI Readiness Assessment"}]," · ",["$","a",null,{"href":"https://calendly.com/allan-safehavenai/30min","style":{"color":"var(--brand)","fontWeight":600},"children":"Book a discovery call"}]]}]]}]
