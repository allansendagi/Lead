28:I[6203,["619","static/chunks/619-ba102abea3e3d0e4.js","549","static/chunks/app/(site)/resources/%5Bslug%5D/page-82b918b41d4220bf.js"],"default"]
1a:["$","p","2",{"children":"The solution is not a better tool. It is the right sequence. This guide walks you through exactly how to implement AI in your business correctly — from the first strategic question you need to answer all the way to a live, working AI system that improves over time."}]
1b:["$","div",null,{"className":"cta-box","style":{"margin":"32px 0"},"children":["$","$L27",null,{"href":"/","location":"resource_mid_how-to-implement-ai-in-business-qatar"}]}]
1c:["$","section","0",{"children":[["$","h2",null,{"children":"Why Most AI Projects in Qatar Fail Before They Start"}],"$undefined",[["$","p","0",{"children":"Before your business invests a single riyal in AI, there are three questions you need to be able to answer clearly: What specific business goal will AI help us achieve? Which of our workflows have the highest potential for AI — and how do we know? What does our implementation roadmap look like for the next 90 days?"}],["$","p","1",{"children":"If you cannot answer all three, you are not behind. You simply have not gone through the right process yet. But starting without these answers is the most expensive mistake in AI adoption — because you end up buying tools that solve problems you have not properly defined."}],["$","p","2",{"children":"The right order is this: business goal first, workflow analysis second, tool selection last."}]]]}]
1d:["$","section","1",{"children":[["$","h2",null,{"children":"The Right Order: A Framework Built for Qatar SMEs"}],"$undefined",[["$","p","0",{"children":"The AI Navigator framework is an 11-step system developed specifically for SMEs — businesses with real workflows, real constraints, and no time to waste on AI experiments that go nowhere. It was built on one core principle: AI should serve your business goals, not the other way around."}]]]}]
1e:["$","section","2",{"children":[["$","h2",null,{"children":"Step 1: Define Your Strategic Vision"}],"$undefined",[["$","p","0",{"children":"Every successful AI implementation starts with a single, clearly stated business goal. Not \"we want to use AI\" — that is not a goal. A goal sounds like: \"We want to reduce the time our team spends on customer follow-up by 40%.\" The Strategic Vision Canvas captures four things: your business goal, the specific AI use case you are targeting, the outcomes you expect, and the criteria by which you will measure success."}],["$","p","1",{"children":"Most businesses skip this step entirely. That is why their projects drift."}]]]}]
1f:["$","section","3",{"children":[["$","h2",null,{"children":"Step 2: Assess Your Starting Point"}],"$undefined",[["$","p","0",{"children":"Before you can plan where to go, you need to know honestly where you are. The Starting Point Analysis asks three questions about your current state: Is the workflow you want to improve currently manual? Is it already running on software that is slow or inaccurate? Or are you facing an entirely new problem you have never solved before?"}],["$","p","1",{"children":"Each of these starting points leads to a different AI strategy. Getting this diagnosis right saves months of misdirected effort."}]]]}]
20:["$","section","4",{"children":[["$","h2",null,{"children":"Step 3: Choose Your Strategy — Evolutionary or Revolutionary"}],"$undefined",[["$","p","0",{"children":"An Evolutionary strategy enhances what already exists — lower risk, faster results, easier for your team to adopt. A Revolutionary strategy redesigns a workflow from the ground up with AI at the centre — higher impact, longer timeline, requires stronger leadership commitment."}],["$","p","1",{"children":"For most Qatar SMEs starting their AI journey, Evolutionary is the right choice. Quick wins build confidence, generate data, and fund the next phase."}]]]}]
21:["$","section","5",{"children":[["$","h2",null,{"children":"Steps 4–11: From Workflow Mapping to Live Execution"}],"$undefined",[["$","p","0",{"children":"Steps 4 through 9 cover Strategy Preferences, Workflow Mapping, Task Deconstruction, the AI Task Canvas, Process Mapping, and Tool Identification — each producing a written document that informs the next step. Step 10 produces your Phased Implementation Plan. Step 11 begins execution and establishes the governance framework."}],["$","p","1",{"children":"For most Qatar SMEs, the AI Navigator process runs across 30 days. By Day 30 you have a complete, written AI implementation plan. The first phase of execution begins."}]]]}]
22:["$","section","6",{"children":[["$","h2",null,{"children":"Is Your Business Ready to Start?"}],"$undefined",[["$","p","0",{"children":"Before committing to any AI project, take the 3-minute AI Readiness Assessment. It evaluates your business across five dimensions — workflow type, decision complexity, data readiness, process volume, and team size — and gives you a personalised readiness score based on the AI Navigator framework."}]]]}]
23:["$","section",null,{"children":[["$","h2",null,{"children":"Frequently Asked Questions"}],["$","$L28",null,{"faqs":[{"q":"How long does it take to implement AI in a business in Qatar?","a":"For an SME, the planning phase takes 30 days using the AI Navigator framework. The first implementation phase — deploying your highest-priority AI use case — typically takes a further 4–8 weeks depending on complexity. The full journey from first session to live AI running in your business is usually 2–3 months for Tier 1 use cases."},{"q":"Do I need a technical team to implement AI?","a":"Not for the planning phase. The AI Navigator framework is designed for business owners and managers — not developers. You will need technical support for the implementation phase, but the planning process is structured so that any competent developer or technology partner can execute from the written plan you produce."},{"q":"What industries does the AI Navigator framework work for?","a":"Any business with repeatable workflows. The framework has been applied to retail, logistics, financial services, legal, healthcare, hospitality, real estate, and professional services. The process is industry-agnostic because it starts with your specific workflows rather than assuming what AI should do."},{"q":"Is my data safe if I use AI in Qatar?","a":"Qatar's PDPPL requires that businesses handling customer personal data keep it within Qatar. All AI implementations guided by the AI Navigator framework are designed to be PDPPL-compliant, using infrastructure such as Microsoft Azure Qatar and Ooredoo's Sovereign AI Cloud."},{"q":"How do I choose an AI consultant in Qatar?","a":"The most important question to ask any AI consultant is: do you start with the business goal or the tool? A consultant who leads with tool recommendations before understanding your workflows is selling you the wrong thing. The right consultant starts with your business problem, maps your processes, and only recommends tools after the strategy is defined."}]}]]}]
24:["$","div",null,{"className":"cta-box","children":[["$","h2",null,{"style":{"marginTop":0},"children":"Ready to assess your AI readiness?"}],["$","p",null,{"children":"The AI Readiness Assessment evaluates your business across five dimensions — workflow type, decision complexity, data availability, process volume, and team size — and gives you a personalised score with specific recommended next steps. It takes three minutes."}],["$","$L27",null,{"href":"/","location":"resource_bottom_how-to-implement-ai-in-business-qatar"}]]}]
25:["$","div",null,{"className":"author-bio","children":[["$","p",null,{"children":[["$","strong",null,{"children":"Allan Sendagi"}]," is the author of ",["$","em",null,{"children":"The AI Roadmap"}]," and founder of SafeHaven AI. He works with SMEs across Qatar and the GCC to build structured AI implementation plans using the AI Navigator framework."]}],["$","p",null,{"style":{"marginTop":8},"children":[["$","a",null,{"href":"/","style":{"color":"var(--brand)","fontWeight":600},"children":"Take the free AI Readiness Assessment"}]," · ",["$","a",null,{"href":"https://calendly.com/allan-safehavenai/30min","style":{"color":"var(--brand)","fontWeight":600},"children":"Book a discovery call"}]]}]]}]
