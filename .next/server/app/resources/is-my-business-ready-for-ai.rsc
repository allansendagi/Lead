13:{"metadata":[["$","title","0",{"children":"Is Your Business Ready for AI? 5 Questions to Find Out | AI Navigator"}],["$","meta","1",{"name":"description","content":"Not sure if your business is ready for AI? These 5 questions — drawn from the AI Navigator framework — tell you exactly where you stand and what to do next. Takes 3 minutes."}],["$","link","2",{"rel":"canonical","href":"https://www.ainavsystem.com/resources/is-my-business-ready-for-ai/"}],["$","meta","3",{"property":"og:title","content":"Is Your Business Ready for AI? 5 Questions to Find Out"}],["$","meta","4",{"property":"og:description","content":"Not sure if your business is ready for AI? These 5 questions — drawn from the AI Navigator framework — tell you exactly where you stand and what to do next. Takes 3 minutes."}],["$","meta","5",{"property":"og:url","content":"https://www.ainavsystem.com/resources/is-my-business-ready-for-ai/"}],["$","meta","6",{"property":"og:type","content":"article"}],["$","meta","7",{"name":"twitter:card","content":"summary"}],["$","meta","8",{"name":"twitter:title","content":"Is Your Business Ready for AI? 5 Questions to Find Out"}],["$","meta","9",{"name":"twitter:description","content":"Not sure if your business is ready for AI? These 5 questions — drawn from the AI Navigator framework — tell you exactly where you stand and what to do next. Takes 3 minutes."}]],"error":null,"digest":"$undefined"}
