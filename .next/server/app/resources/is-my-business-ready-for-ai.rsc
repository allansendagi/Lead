1a:["$","div",null,{"className":"cta-box","style":{"margin":"32px 0"},"children":["$","$L25",null,{"href":"/","location":"resource_mid_is-my-business-ready-for-ai"}]}]
1b:["$","section","0",{"children":[["$","h2",null,{"children":"Question 1: How Does Your Most Important Workflow Currently Run?"}],"$undefined",[["$","p","0",{"children":"Start by identifying the single workflow in your business that takes the most time, causes the most errors, or creates the most friction. Now ask: how does it run today? <strong>Manual process</strong> — your team handles it through WhatsApp messages, spreadsheets, email threads, or paper. <strong>Existing software</strong> — there is a system in place, but it is slow, inaccurate, or limited. <strong>New problem</strong> — this is a challenge your business has not faced before with no existing process."}],["$","p","1",{"children":"Each starting point leads to a different AI strategy. Knowing your starting point tells you which path you are on before you take a single step."}]]]}]
1c:["$","section","1",{"children":[["$","h2",null,{"children":"Question 2: How Complex Are the Decisions in That Workflow?"}],"$undefined",[["$","p","0",{"children":"AI is extraordinarily good at repetitive decisions — tasks that follow clear rules, have consistent inputs, and produce predictable outputs. Assess your workflow: <strong>High complexity</strong> — the decisions require significant expertise or creative judgment. <strong>Medium complexity</strong> — routine decisions with occasional exceptions. <strong>Low complexity, rule-based</strong> — the decisions are clear; if X, then Y."}],["$","p","1",{"children":"Low complexity and high volume is one of the highest-ROI AI opportunities available. Repetitive, rule-based, high-frequency tasks are where AI delivers the fastest and most measurable returns."}]]]}]
1d:["$","section","2",{"children":[["$","h2",null,{"children":"Question 3: How Available and Organised Is Your Data?"}],"$undefined",[["$","p","0",{"children":"Data is the fuel for AI. Assess your data honestly: <strong>Poor or no data</strong> — data is either not captured digitally at all, scattered across disconnected systems, or not available in a usable form. <strong>Some data, needs work</strong> — data exists but is incomplete or not consistently structured. <strong>Good structured data</strong> — data is captured digitally, fairly consistent in format, and accessible."}],["$","p","1",{"children":"If your data is poor or non-existent, start with generative AI use cases — product description writing, customer communication drafting — that can work with minimal existing data."}]]]}]
1e:["$","section","3",{"children":[["$","h2",null,{"children":"Question 4: How Often Does That Workflow Run?"}],"$undefined",[["$","p","0",{"children":"<strong>Low volume</strong> — this workflow happens infrequently, monthly or less. <strong>Medium volume</strong> — weekly occurrence. <strong>High volume, daily</strong> — this workflow runs every day, multiple times a day."}],["$","p","1",{"children":"High-volume, high-frequency workflows are your priority AI candidates. The same AI implementation that saves 10 minutes per instance saves 50 hours over a year if the workflow runs 300 times."}]]]}]
1f:["$","section","4",{"children":[["$","h2",null,{"children":"Question 5: How Many People Are on Your Team?"}],"$undefined",[["$","p","0",{"children":"<strong>1–5 people</strong> — a small team where every hour saved matters directly. <strong>6–20 people</strong> — a growing team where process inefficiencies are starting to compound. <strong>20 or more people</strong> — an established team where AI adoption requires alignment across functions."}],["$","p","1",{"children":"For teams under 10, the Starter AI Navigator engagement is typically sufficient. For teams of 10 and above, the Full Roadmap engagement produces a complete plan that addresses multiple workflows and defines the governance layer."}]]]}]
20:["$","section","5",{"children":[["$","h2",null,{"children":"Take the Full Assessment in 3 Minutes"}],"$undefined",[["$","p","0",{"children":"These five questions give you a directional picture. The full AI Readiness Assessment gives you a precise score across all five dimensions — with a personalised report showing exactly where you stand, what your strongest AI opportunities are, and what your recommended next step is."}]]]}]
21:["$","section",null,{"children":[["$","h2",null,{"children":"Frequently Asked Questions"}],["$","$L26",null,{"faqs":[{"q":"What does the AI Readiness Assessment actually measure?","a":"The assessment evaluates your business across five dimensions: your current workflow type, the complexity of decisions in that workflow, the availability and quality of your data, the frequency and volume of the workflow, and your team size. Scores combine into an overall AI Readiness level — from Foundation First (5–7) through Getting Ready (8–10), Good Candidate (11–12), and Ready to Navigate (13–15)."},{"q":"What if I score low on readiness?","a":"A low readiness score does not mean you cannot start. It means you start differently. Every readiness band has a recommended next action. A business in the Foundation First band typically needs to focus on process standardisation and data capture before deploying AI."},{"q":"Can I be ready for AI in one area of my business but not another?","a":"Yes, and this is actually the most common situation. A company might be ready to deploy AI in customer communication while its inventory management workflow needs foundational work first. The AI Navigator framework helps you identify and sequence these opportunities correctly."},{"q":"Does AI readiness require a large technology budget?","a":"No. Some of the highest-ROI AI implementations for SMEs involve using existing large language models configured with your specific business context rather than building custom models from scratch. The AI Navigator framework specifically distinguishes between use cases that require significant investment and those that can be deployed quickly and cost-effectively."},{"q":"How quickly can a business go from not ready to ready?","a":"For Tier 1 quick wins — use cases that do not require historical training data — a business can go from assessment to deployed AI in 30 to 60 days. For data-dependent Tier 2 use cases, data collection adds 30 to 60 days. For Tier 3 implementations, 6 to 12 months of live operational data is typically required."}]}]]}]
22:["$","div",null,{"className":"cta-box","children":[["$","h2",null,{"style":{"marginTop":0},"children":"Ready to assess your AI readiness?"}],["$","p",null,{"children":"The AI Readiness Assessment evaluates your business across five dimensions — workflow type, decision complexity, data availability, process volume, and team size — and gives you a personalised score with specific recommended next steps. It takes three minutes."}],["$","$L25",null,{"href":"/","location":"resource_bottom_is-my-business-ready-for-ai"}]]}]
23:["$","div",null,{"className":"author-bio","children":[["$","p",null,{"children":[["$","strong",null,{"children":"Allan Sendagi"}]," is the author of ",["$","em",null,{"children":"The AI Roadmap"}]," and founder of SafeHaven AI. He works with SMEs across Qatar and the GCC to build structured AI implementation plans using the AI Navigator framework."]}],["$","p",null,{"style":{"marginTop":8},"children":[["$","a",null,{"href":"/","style":{"color":"var(--brand)","fontWeight":600},"children":"Take the free AI Readiness Assessment"}]," · ",["$","a",null,{"href":"https://calendly.com/allan-safehavenai/30min","style":{"color":"var(--brand)","fontWeight":600},"children":"Book a discovery call"}]]}]]}]
