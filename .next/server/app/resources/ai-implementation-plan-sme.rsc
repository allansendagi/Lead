13:{"metadata":[["$","title","0",{"children":"What Is an AI Implementation Plan? A Practical Guide for SMEs | AI Navigator"}],["$","meta","1",{"name":"description","content":"Learn what a real AI implementation plan looks like for a small or medium-sized business. The AI Navigator framework breaks it into 11 clear steps, each producing a written document you own."}],["$","link","2",{"rel":"canonical","href":"https://www.ainavsystem.com/resources/ai-implementation-plan-sme/"}],["$","meta","3",{"property":"og:title","content":"What Is an AI Implementation Plan? A Practical Guide for SMEs"}],["$","meta","4",{"property":"og:description","content":"Learn what a real AI implementation plan looks like for a small or medium-sized business. The AI Navigator framework breaks it into 11 clear steps, each producing a written document you own."}],["$","meta","5",{"property":"og:url","content":"https://www.ainavsystem.com/resources/ai-implementation-plan-sme/"}],["$","meta","6",{"property":"og:type","content":"article"}],["$","meta","7",{"name":"twitter:card","content":"summary"}],["$","meta","8",{"name":"twitter:title","content":"What Is an AI Implementation Plan? A Practical Guide for SMEs"}],["$","meta","9",{"name":"twitter:description","content":"Learn what a real AI implementation plan looks like for a small or medium-sized business. The AI Navigator framework breaks it into 11 clear steps, each producing a written document you own."}]],"error":null,"digest":"$undefined"}
