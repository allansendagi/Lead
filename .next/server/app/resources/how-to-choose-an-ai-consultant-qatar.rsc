1a:["$","div",null,{"className":"cta-box","style":{"margin":"32px 0"},"children":["$","$L23",null,{"href":"/","location":"resource_mid_how-to-choose-an-ai-consultant-qatar"}]}]
1b:["$","section","0",{"children":[["$","h2",null,{"children":"Question 1: Do you start with the business goal or the tool?"}],"$undefined",[["$","p","0",{"children":"The answer to this question tells you more about a consultant's approach than any other. A consultant who leads with tool recommendations — 'you should use this AI platform' — before understanding your workflows has reversed the order. Tool selection is Step 9 of 11 in a properly structured AI process. A consultant who starts with the business goal, maps the workflows, scores the tasks, and designs the AI use case before looking at any vendor is doing it correctly."}]]]}]
1c:["$","section","1",{"children":[["$","h2",null,{"children":"Question 2: What written documents will I hold at the end of the engagement?"}],"$undefined",[["$","p","0",{"children":"An engagement that produces a strategy you own — written down, structured, transferable — is fundamentally different from one that produces verbal recommendations and presentation slides. Ask specifically: which written documents will I hold? Can I share them with a developer and have them build from them independently? A consultant who cannot answer this question with a specific list is not delivering a plan."}]]]}]
1d:["$","section","2",{"children":[["$","h2",null,{"children":"Question 3: How do you handle data sovereignty requirements under PDPPL?"}],"$undefined",[["$","p","0",{"children":"Any consultant operating in Qatar who does not know what PDPPL is, or who does not treat data residency as a tool selection criterion, is not equipped to advise businesses in Qatar. The consultant should be able to tell you immediately what PDPPL requires, which cloud infrastructure options are compliant, and how their tool recommendations account for those requirements."}]]]}]
1e:["$","section","3",{"children":[["$","h2",null,{"children":"Questions 4–7"}],"$undefined",[["$","p","0",{"children":"<strong>Q4: Can you show me examples of AI implementations you have done in businesses like mine?</strong> Look for specificity — specific workflows improved, specific metrics achieved, specific tools deployed. Vague case studies are a red flag."}],["$","p","1",{"children":"<strong>Q5: How do you distinguish between Evolutionary and Revolutionary AI strategies?</strong> A consultant who cannot explain this distinction has not worked through a structured methodology. The answer reveals whether their approach is principled or ad hoc."}],["$","p","2",{"children":"<strong>Q6: What is your approach to change management during AI implementation?</strong> AI implementation that does not consider how the team will adopt the system often fails at the adoption stage rather than the technical stage."}],["$","p","3",{"children":"<strong>Q7: What happens after the engagement ends?</strong> A plan that you can execute independently is worth more than one that requires the consultant's ongoing presence to function. Ask whether the deliverables are yours to use and build on without further dependency."}]]]}]
1f:["$","section",null,{"children":[["$","h2",null,{"children":"Frequently Asked Questions"}],["$","$L24",null,{"faqs":[{"q":"What is a reasonable price for AI consulting in Qatar?","a":"For an SME-focused AI strategy engagement that produces a complete implementation plan, the range is $997 to $2,497 depending on team size and scope. Enterprise AI consulting from global firms starts at QAR 150,000. The price difference reflects methodology depth, deliverable specificity, and seniority — not necessarily quality."},{"q":"Should I hire a local or international AI consultant?","a":"Both can be excellent. The critical advantage of a local consultant with GCC experience is knowledge of the regulatory environment — specifically PDPPL compliance — and understanding of the cultural and commercial context of business in Qatar. An international consultant without this knowledge may recommend tools or approaches that are not compliant with Qatari data protection law."},{"q":"How do I evaluate an AI consultant's technical credibility?","a":"Ask them to explain a specific AI concept relevant to your business — not in abstract terms, but in terms of your specific workflow. A credible consultant should be able to explain how a WhatsApp AI concierge works for your specific industry, what data it needs, and what human oversight structure it requires — without resorting to jargon."},{"q":"What red flags should I watch for in AI consulting proposals?","a":"Three red flags: tool recommendations before workflow analysis; vague deliverables ('a roadmap', 'a strategy presentation'); and pricing that scales with implementation time rather than defined deliverables. A fixed-fee engagement with specified written deliverables is a sign of a consultant who knows what they are doing."},{"q":"How do I know if an AI consultant's methodology is genuinely structured?","a":"Ask them to describe their process step by step. A structured methodology has specific stages, each producing a specific output, each output informing the next stage. If the description is vague or varies between conversations, the methodology is not structured — it is improvised."}]}]]}]
20:["$","div",null,{"className":"cta-box","children":[["$","h2",null,{"style":{"marginTop":0},"children":"Ready to assess your AI readiness?"}],["$","p",null,{"children":"The AI Readiness Assessment evaluates your business across five dimensions — workflow type, decision complexity, data availability, process volume, and team size — and gives you a personalised score with specific recommended next steps. It takes three minutes."}],["$","$L23",null,{"href":"/","location":"resource_bottom_how-to-choose-an-ai-consultant-qatar"}]]}]
21:["$","div",null,{"className":"author-bio","children":[["$","p",null,{"children":[["$","strong",null,{"children":"Allan Sendagi"}]," is the author of ",["$","em",null,{"children":"The AI Roadmap"}]," and founder of SafeHaven AI. He works with SMEs across Qatar and the GCC to build structured AI implementation plans using the AI Navigator framework."]}],["$","p",null,{"style":{"marginTop":8},"children":[["$","a",null,{"href":"/","style":{"color":"var(--brand)","fontWeight":600},"children":"Take the free AI Readiness Assessment"}]," · ",["$","a",null,{"href":"https://calendly.com/allan-safehavenai/30min","style":{"color":"var(--brand)","fontWeight":600},"children":"Book a discovery call"}]]}]]}]
