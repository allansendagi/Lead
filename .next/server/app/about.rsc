b:["$","$1","c",{"children":[["$","div",null,{"className":"article-wrap","children":[["$","h1",null,{"children":"About Allan Sendagi"}],["$","div",null,{"style":{"background":"#f9fafb","borderRadius":12,"padding":24,"marginBottom":32,"display":"flex","alignItems":"flex-start","gap":24,"flexWrap":"wrap"},"children":[["$","div",null,{"style":{"width":120,"height":120,"borderRadius":"50%","background":"#e5e7eb","flexShrink":0,"display":"flex","alignItems":"center","justifyContent":"center","fontSize":13,"color":"#9ca3af"},"children":"Photo"}],["$","div",null,{"children":[["$","p",null,{"style":{"fontWeight":700,"fontSize":20,"margin":"0 0 4px"},"children":"Allan Sendagi"}],["$","p",null,{"style":{"color":"#6b7280","margin":"0 0 8px","fontSize":15},"children":"Founder, SafeHaven AI · Author, The AI Roadmap"}],["$","a",null,{"href":"https://www.linkedin.com/in/allansendagi/","target":"_blank","rel":"noopener noreferrer","style":{"fontSize":14,"color":"#1C1714","fontWeight":600},"children":"LinkedIn Profile →"}]]}]]}],["$","p",null,{"children":"Allan Sendagi is an AI implementation consultant based in Doha, Qatar. He works with business owners and senior managers across Qatar and the GCC who want to implement AI practically — with a clear plan, a structured sequence, and measurable outcomes — rather than experimenting with tools and hoping for the best."}],["$","p",null,{"children":"His work is structured around one framework: the AI Navigator. The framework addresses the most common reason AI projects fail — not the technology, but the absence of a plan before a tool. Every AI Navigator engagement begins with an AI Readiness Assessment, moves through a three-tier use case roadmap, and ends with a system that is live, generating data, and compounding in value over time."}],["$","h2",null,{"children":"The AI Roadmap"}],["$","p",null,{"children":["Allan is the author of ",["$","em",null,{"children":"The AI Roadmap"}]," — a practical guide to AI implementation for business owners who have no prior technical background. The book covers the AI Navigator framework in full: how to assess readiness, how to select use cases, how to sequence implementation, and how to measure outcomes. It is available on Gumroad."]}],["$","p",null,{"children":["$","a",null,{"href":"https://allansendagi.gumroad.com/l/ainavigatorsystem","target":"_blank","rel":"noopener noreferrer","style":{"color":"#1C1714","fontWeight":600},"children":"Get The AI Roadmap on Gumroad →"}]}],["$","h2",null,{"children":"SafeHaven AI"}],["$","p",null,{"children":"SafeHaven AI is the consulting practice through which Allan delivers AI Navigator engagements. The practice operates in Qatar and works with clients across the GCC. Every engagement is structured, documented, and delivered with a clear outcome — a functioning AI system, a trained team, and a roadmap for the next phase."}],["$","h2",null,{"children":"Work With Allan"}],["$","p",null,{"children":"If you are a business owner or manager in Qatar or the GCC and you are ready to implement AI with a structured plan rather than another experiment, the right starting point is the free AI Readiness Assessment. It takes three minutes and produces a personalised score with specific next steps."}],["$","div",null,{"className":"cta-box","children":[["$","h2",null,{"style":{"marginTop":0},"children":"Start with the AI Readiness Assessment"}],["$","a",null,{"href":"/","style":{"display":"inline-flex","alignItems":"center","background":"#1C1714","color":"#fff","padding":"15px 28px","borderRadius":10,"fontSize":16,"fontWeight":600,"textDecoration":"none"},"children":"Take the free AI Readiness Assessment →"}],["$","p",null,{"style":{"marginTop":12,"fontSize":15},"children":["Or"," ",["$","a",null,{"href":"https://calendly.com/allan-safehavenai/30min","style":{"color":"#1C1714","fontWeight":600},"children":"book a free 15-minute discovery call"}]," ","to discuss your specific situation."]}]]}]]}],null,["$","$L10",null,{"children":["$L11",["