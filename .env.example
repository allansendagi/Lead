# Supabase — get these from your Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here   # Settings → API → service_role (keep secret)

# WhatsApp Business number — digits only, include country code, no + or spaces
# Example Qatar: 97450000000 | Example UK: 447911123456
WHATSAPP_NUMBER=97450000000

# Optional: restrict API to your Vercel domain (recommended in production)
# ALLOWED_ORIGIN=https://your-app.vercel.app
